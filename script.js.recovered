/**
 * تطبيق إدارة المداخيل والنفقات - MEUBLE ART DESIGN
 * نظام متكامل لإدارة الفواتير، العمال الدائمين، العمال العرضيين، والمصاريف
 */

const SS = SpreadsheetApp.getActiveSpreadsheet();
const PASSWORD_KEY = 'ADMIN_PASSWORD';
const ADMIN_EMAIL = 'meubleartdesign@gmail.com';

const SHEETS = {
  INVOICES: 'Invoices',
  PAYMENTS: 'Payments',
  WORKERS: 'Workers',
  WORKER_PAYMENTS: 'WorkerPayments',
  TRANSPORT_PAYMENTS: 'TransportPayments',
  SHOPS: 'Shops',
  SHOP_PAYMENTS: 'ShopPayments',
  ELECTRICITY_BILLS: 'ElectricityBills',
  CASUAL_WORKERS: 'CasualWorkers',
  CASUAL_WORK_RECORDS: 'CasualWorkRecords',
  CASUAL_WORKER_PAYMENTS: 'CasualWorkerPayments'
};

// ====================================================================
// وظائف المزامنة والبيانات الشاملة (NEW)
// ====================================================================

function getAllDataForClient() {
  try {
    // Fetch all data lists
    const invoices = getInvoices({});
    const workers = getWorkers({ showInactive: true });
    const casualWorkersData = getCasualWorkers({}); 
    const transport = getTransportPayments({});
    const shops = getShops({});
    const electricity = getElectricityBills();
    
    // Raw data for specific editing needs and local calculations
    const workerPayments = getData(SHEETS.WORKER_PAYMENTS);
    const shopPayments = getData(SHEETS.SHOP_PAYMENTS);
    const casualWorkerPayments = getData(SHEETS.CASUAL_WORKER_PAYMENTS);
    const casualWorkRecords = getData(SHEETS.CASUAL_WORK_RECORDS);

    return {
      success: true,
      data: {
        invoices: invoices.error ? [] : invoices,
        workers: workers.error ? [] : workers,
        casualWorkers: casualWorkersData.error ? [] : casualWorkersData.workers,
        casualWorkerStats: casualWorkersData.stats || {},
        transport: transport.error ? [] : transport.payments,
        shops: shops.error ? [] : shops,
        electricity: electricity.error ? [] : electricity,
        rawWorkerPayments: workerPayments.error ? [] : workerPayments,
        rawShopPayments: shopPayments.error ? [] : shopPayments,
        rawCasualPayments: casualWorkerPayments.error ? [] : casualWorkerPayments,
        rawCasualRecords: casualWorkRecords.error ? [] : casualWorkRecords
      }
    };
  } catch (e) {
    return { success: false, error: e.message };
  }
}

// ====================================================================
// وظائف إدارة كلمة المرور
// ====================================================================

function getAdminPassword() {
    const scriptProperties = PropertiesService.getScriptProperties();
    let currentPassword = scriptProperties.getProperty(PASSWORD_KEY);
   
    if (!currentPassword) {
        currentPassword = 'Meuble2024@';
        scriptProperties.setProperty(PASSWORD_KEY, currentPassword);
    }
    return currentPassword;
}

function doLogin(password) {
    const adminPassword = getAdminPassword();
    if (password === adminPassword) {
        return { success: true };
    } else {
        return { success: false, error: 'كلمة المرور خاطئة.' };
    }
}

function changeAdminPassword(currentPassword, newPassword) {
    const scriptProperties = PropertiesService.getScriptProperties();
    const adminPassword = getAdminPassword();

    if (currentPassword !== adminPassword) {
        return { success: false, error: 'كلمة المرور الحالية غير صحيحة.' };
    }

    if (!newPassword || newPassword.length < 8) {
        return { success: false, error: 'يجب أن لا تقل كلمة المرور الجديدة عن 8 أحرف.' };
    }

    scriptProperties.setProperty(PASSWORD_KEY, newPassword);
    return { success: true, message: 'تم تغيير كلمة المرور بنجاح.' };
}

