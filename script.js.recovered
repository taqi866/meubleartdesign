  }
}

// ====================================================================
// وظائف مصاريف الكهرباء
// ====================================================================

function getElectricityBills(year) {
  try {
    var billsData = getData(SHEETS.ELECTRICITY_BILLS);
    if (billsData.error) return billsData;

    var filteredBills = billsData;
    if (year) {
      filteredBills = billsData.filter(function(bill) {
        return bill.Year == year;
      });
    }

    return filteredBills;
  } catch (e) {
    return { error: e.message };
  }
}

function addElectricityBill(data) {
  try {
    var newBill = {
      ElectricityID: generateID(),
      Month: data.Month,
      Year: data.Year,
      Amount: parseFloat(data.Amount) || 0,
      PaymentDate: data.PaymentDate || Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd'),
      BillNo: data.BillNo || '',
      Location: data.Location || 'الرئيسي',
      Notes: data.Notes || '',
      CreatedDate: Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd HH:mm:ss')
    };
   
    appendRow(SHEETS.ELECTRICITY_BILLS, newBill, ['Amount']);
    return { success: true, message: 'تم إضافة فاتورة الكهرباء بنجاح.', bill: newBill };
  } catch (e) {
    return { success: false, error: e.message };
  }
}

function editElectricityBill(electricityId, updatedData) {
