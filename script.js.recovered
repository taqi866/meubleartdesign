// ====================================================================
// وظائف العمال العرضيين
// ====================================================================

function getCasualWorkers(filters) {
  try {
    var casualWorkersData = getData(SHEETS.CASUAL_WORKERS);
    var workRecordsData = getData(SHEETS.CASUAL_WORK_RECORDS);
    var paymentsData = getData(SHEETS.CASUAL_WORKER_PAYMENTS);

    if (casualWorkersData.error) return casualWorkersData;
    if (workRecordsData.error) return workRecordsData;
    if (paymentsData.error) return paymentsData;

    var casualWorkers = casualWorkersData;
    var workRecords = workRecordsData;
    var payments = paymentsData;

    // حساب الإحصائيات الإجمالية
    var totalDaysWorked = 0;
    var totalEarned = 0;
    var totalPaid = 0;

    var workersWithStats = casualWorkers.map(function(worker) {
      var workerId = worker.CasualWorkerID;
      
      // حساب أيام العمل لهذا العامل
      var workerWorkRecords = workRecords.filter(function(record) {
        return record.CasualWorkerID === workerId;
      });

      // تصفية حسب السنة والشهر إذا تم تحديدها
      if (filters.year || filters.month) {
        workerWorkRecords = workerWorkRecords.filter(function(record) {
          return isDateInMonthAndYear(record.WorkDate, filters.month, filters.year);
        });
      }

      var daysWorked = workerWorkRecords.reduce(function(sum, record) {
        return sum + (parseFloat(record.DaysWorked) || 0);
      }, 0);

      var earned = workerWorkRecords.reduce(function(sum, record) {
        return sum + (parseFloat(record.Amount) || 0);
      }, 0);
      
      // حساب المدفوعات لهذا العامل
      var workerPayments = payments.filter(function(payment) {
        return payment.CasualWorkerID === workerId;
      });

      // تصفية المدفوعات حسب السنة والشهر
      if (filters.year || filters.month) {
        workerPayments = workerPayments.filter(function(payment) {
          return isDateInMonthAndYear(payment.PaymentDate, filters.month, filters.year);
        });
      }

      var paid = workerPayments.reduce(function(sum, payment) {
        return sum + (parseFloat(payment.PaidAmount) || 0);
      }, 0);

      var remaining = earned - paid;

      // تحديث الإحصائيات الإجمالية
      totalDaysWorked += daysWorked;
      totalEarned += earned;
      totalPaid += paid;

      return {
        CasualWorkerID: worker.CasualWorkerID,
        Name: worker.Name,
        Phone: worker.Phone || '',
        DailyRate: '0.00', // No longer used as primary calculation
        WorkType: worker.WorkType || '',
        Notes: worker.Notes || '',
        DaysWorked: daysWorked.toFixed(1),
        TotalEarned: earned.toFixed(2),
        TotalPaid: paid.toFixed(2),
        Remaining: remaining.toFixed(2),
        rowIndex: worker.rowIndex
      };
    });

    return {
      workers: workersWithStats,
      stats: {
        totalDaysWorked: totalDaysWorked.toFixed(1),
        totalEarned: totalEarned.toFixed(2),
        totalPaid: totalPaid.toFixed(2),
        totalRemaining: (totalEarned - totalPaid).toFixed(2)
      }
    };

  } catch (e) {
    return { error: e.message };
  }
}

function getCasualWorkersForSelect() {
  try {
    var casualWorkers = getData(SHEETS.CASUAL_WORKERS);
    if (casualWorkers.error) return casualWorkers;
    
