function getTransportPayments(filters) {
  try {
    var paymentsData = getData(SHEETS.TRANSPORT_PAYMENTS);
    if (paymentsData.error) throw new Error(paymentsData.error);
   
    var filteredPayments = paymentsData;
    if (filters.year || filters.month) {
        filteredPayments = paymentsData.filter(function(p) {
            return isDateInMonthAndYear(p.Date, filters.month, filters.year);
        });
    }
   
    var totalPaid = filteredPayments.reduce(function(sum, p) { return sum + (parseFloat(p.PaidAmount) || 0); }, 0);

    return {
        success: true,
        payments: filteredPayments,
        summary: {
            totalPaid: totalPaid.toFixed(2)
        }
    };
  } catch (e) {
    return { success: false, payments: [], summary: { totalPaid: '0.00' }, error: e.message };
  }
}

