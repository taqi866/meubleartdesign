  }
}

function getCasualWorkerDetails(casualWorkerId) {
  try {
    var casualWorkers = getData(SHEETS.CASUAL_WORKERS);
    var worker = casualWorkers.find(function(w) { return w.CasualWorkerID === casualWorkerId; });
    
    if (!worker) {
      throw new Error("العامل غير موجود.");
    }

    var workRecords = getData(SHEETS.CASUAL_WORK_RECORDS);
    var payments = getData(SHEETS.CASUAL_WORKER_PAYMENTS);

    // تصفية سجلات العمل الخاصة بهذا العامل
    var workerWorkRecords = workRecords.filter(function(record) {
      return record.CasualWorkerID === casualWorkerId;
    }).sort(function(a, b) {
      return new Date(b.WorkDate) - new Date(a.WorkDate);
    });

    // تصفية المدفوعات الخاصة بهذا العامل
    var workerPayments = payments.filter(function(payment) {
      return payment.CasualWorkerID === casualWorkerId;
    }).sort(function(a, b) {
      return new Date(b.PaymentDate) - new Date(a.PaymentDate);
    });

    // حساب الإحصائيات
    var totalDaysWorked = workerWorkRecords.reduce(function(sum, record) {
      return sum + (parseFloat(record.DaysWorked) || 0);
    }, 0);
    
    var totalEarned = workerWorkRecords.reduce(function(sum, record) { return sum + (parseFloat(record.Amount) || 0); }, 0);
    var totalPaid = workerPayments.reduce(function(sum, payment) {
      return sum + (parseFloat(payment.PaidAmount) || 0);
    }, 0);
    
    var remaining = totalEarned - totalPaid;

    return {
      success: true,
      worker: {
        Name: worker.Name,
        DailyRate: '0.00',
        Phone: worker.Phone || '',
        WorkType: worker.WorkType || '',
        Notes: worker.Notes || ''
      },
      workDays: workerWorkRecords.map(function(record) {
        var days = parseFloat(record.DaysWorked) || 0;
        return {
          WorkDate: record.WorkDate,
          DaysWorked: days.toFixed(1),
          Amount: (parseFloat(record.Amount) || 0).toFixed(2),
          WorkDescription: record.WorkDescription || '',
          Notes: record.Notes || ''
        };
      }),
      payments: workerPayments.map(function(payment) {
        return {
          PaymentDate: payment.PaymentDate,
          PaidAmount: parseFloat(payment.PaidAmount).toFixed(2),
          Notes: payment.Notes || ''
        };
      }),
      stats: {
        totalDaysWorked: totalDaysWorked.toFixed(1),
        totalEarned: totalEarned.toFixed(2),
        totalPaid: totalPaid.toFixed(2),
        remaining: remaining.toFixed(2)
      }
    };

  } catch (e) {
    return { success: false, error: e.message };
  }
}

